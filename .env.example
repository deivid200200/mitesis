# Variables de Entorno - Ejemplo
# Copia este archivo a .env y completa con tus valores

# Django Settings
SECRET_KEY=tu-secret-key-aqui-cambiar-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de Datos
# Usar SQLite localmente: sqlite:///db.sqlite3
# O PostgreSQL en producción
DATABASE_URL=sqlite:///db.sqlite3

# Email (para notificaciones)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-contraseña-app

# Security
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# AWS S3 (opcional para archivos estáticos/media)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# Logging
LOG_LEVEL=INFO
